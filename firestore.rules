rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'raghvendrasingh9389@gmail.com' ||
        request.auth.token.email == 'developerraghavv@gmail.com'
      );
    }

    function isValidUser(data) {
       return data.keys().hasAll(['email', 'createdAt']) && 
              data.email is string && data.email.size() >= 3 && data.email.size() <= 100 &&
              data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /plugins/{pluginId} {
      allow read: if true;
      allow write: if isAdmin();

      match /versions/{versionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /api_keys/{keyId} {
      // Users can see their own API keys, or admins can see all
      allow read: if isSignedIn() && (request.auth.uid == existing().user_id || isAdmin());
      // Users can generate API keys directly directly via dashboard on frontend, must check ownership
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      // Backend or self updates
      allow update: if isAdmin() || (isSignedIn() && incoming().user_id == request.auth.uid && existing().user_id == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().user_id == request.auth.uid);
    }
    
    match /licenses/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().user_id || isAdmin());
      allow write: if isAdmin();
    }

    match /downloads/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().user_id || isAdmin());
      allow write: if isAdmin();
    }

    match /support_tickets/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().user_id || isAdmin());
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && existing().user_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().user_id || isAdmin());
      allow write: if isAdmin();
    }

    match /validation_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Backend/Express server creates this without admin sdk currently, so needs true write or we add an admin token, but we are using client sdk in backend, so allow create
    }
  }
}
